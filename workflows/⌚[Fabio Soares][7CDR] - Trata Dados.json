        "jsCode": "const body = $node[\"chega_da_fila\"].json[\"content\"][\"body\"] || {};\n\n// Captura segura dos dados (NOVO PAYLOAD)\nconst fullNameAnswer = body[\"name\"] || body[\"Nome\"] || body[\"nome_completo\"] || \"\";\nconst emailAnswer = body[\"email\"] || \"\";\nconst telefoneClienteOriginal = body[\"phonenumber\"] || body[\"phone\"] || body[\"Telefone\"] || \"\";\n\n// UTM (NOVO PAYLOAD)\nconst utm_source   = body[\"utm_source\"]   || \"\";\nconst utm_campaign = body[\"utm_campaign\"] || \"\";\nconst utm_medium   = body[\"utm_medium\"]   || \"\";\nconst utm_term     = body[\"utm_term\"]     || \"\";\nconst utm_content  = body[\"utm_content\"]  || \"\";\n\n// Form info\nconst form_id   = body[\"form_id\"]   || \"\";\nconst form_name = body[\"form_name\"] || \"\";\n\n// URL da página\nconst urlPaginaRaw = body[\"URL da página\"] || body[\"page_url\"] || body[\"url\"] || \"\";\n\n// NOVO → Data + Horário\nconst dataRaw = body[\"Data\"] || \"\";\nconst horarioRaw = body[\"Horário\"] || \"\";\n\n// Funções auxiliares\nfunction capitalizeName(fullName) {\n  if (!fullName) return { fname: \"\", lname: \"\", fullname: \"\" };\n\n  const lowerCaseWords = [\"da\", \"de\", \"do\", \"di\", \"du\"];\n  const words = String(fullName)\n    .toLowerCase()\n    .split(\" \")\n    .filter(Boolean)\n    .map((word, index) => {\n      if (lowerCaseWords.includes(word) && index !== 0) return word;\n      return word.charAt(0).toUpperCase() + word.slice(1);\n    });\n\n  const fname = words.shift() || \"\";\n  const lname = words.join(\" \");\n\n  return { fname, lname, fullname: lname ? `${fname} ${lname}` : fname };\n}\n\nfunction formatEmail(email) {\n  return String(email || \"\").toLowerCase().trim();\n}\n\n// FORMATA DATA\nfunction formatDataCadastro(dataStr, horaStr) {\n  if (!dataStr || !horaStr) return \"\";\n\n  const meses = {\n    janeiro: \"01\",\n    fevereiro: \"02\",\n    março: \"03\",\n    marco: \"03\",\n    abril: \"04\",\n    maio: \"05\",\n    junho: \"06\",\n    julho: \"07\",\n    agosto: \"08\",\n    setembro: \"09\",\n    outubro: \"10\",\n    novembro: \"11\",\n    dezembro: \"12\"\n  };\n\n  const partesData = dataStr.toLowerCase().replace(\",\", \"\").split(\" \");\n  const mes = meses[partesData[0]];\n  const dia = String(partesData[1] || \"\").padStart(2, \"0\");\n  const ano = partesData[2];\n\n  let horaNormalizada = horaStr.toLowerCase().trim();\n  let [hora, minuto] = horaNormalizada.replace(\" pm\", \"\").replace(\" am\", \"\").split(\":\");\n  hora = parseInt(hora, 10);\n\n  if (horaNormalizada.includes(\"pm\") && hora !== 12) {\n    hora += 12;\n  }\n  if (horaNormalizada.includes(\"am\") && hora === 12) {\n    hora = 0;\n  }\n\n  const horaFormatada = String(hora).padStart(2, \"0\");\n  const minutoFormatado = String(minuto || \"00\").padStart(2, \"0\");\n\n  return `${ano}-${mes}-${dia} ${horaFormatada}:${minutoFormatado}:00`;\n}\n\n// LIMPA URL E MANTÉM ATÉ O PATH\nfunction formatPageUrl(url) {\n  if (!url) return \"\";\n\n  try {\n    const parsedUrl = new URL(String(url).trim());\n    return `${parsedUrl.origin}${parsedUrl.pathname}`;\n  } catch (error) {\n    return String(url).split(\"?\")[0].split(\"#\")[0].trim();\n  }\n}\n\n// Tratamento do telefone\nfunction formatTelefone(telefone) {\n  const original = String(telefone || \"\").trim();\n  const telefoneLimpo = original.replace(/\\D/g, \"\");\n\n  if (!telefoneLimpo) return \"\";\n\n  // Se veio com + e não é +55, considera internacional e não mexe\n  if (original.startsWith(\"+\") && !telefoneLimpo.startsWith(\"55\")) {\n    return telefoneLimpo;\n  }\n\n  // Se já veio com 55, trata como número BR\n  if (telefoneLimpo.startsWith(\"55\")) {\n    const DDI = \"55\";\n    const DDD = telefoneLimpo.slice(2, 4);\n    let numero = telefoneLimpo.slice(4);\n\n    if (!DDD || !numero) return telefoneLimpo;\n\n    if (Number(DDD) > 28 && numero.length === 9 && numero.startsWith(\"9\")) {\n      numero = numero.slice(1);\n    } else if (Number(DDD) <= 28 && numero.length === 8) {\n      numero = `9${numero}`;\n    }\n\n    return `${DDI}${DDD}${numero}`;\n  }\n\n  // Se não veio com + e tem tamanho típico BR, assume nacional\n  if (telefoneLimpo.length === 10 || telefoneLimpo.length === 11) {\n    const DDI = \"55\";\n    const DDD = telefoneLimpo.slice(0, 2);\n    let numero = telefoneLimpo.slice(2);\n\n    if (!DDD || !numero) return telefoneLimpo;\n\n    if (Number(DDD) > 28 && numero.length === 9 && numero.startsWith(\"9\")) {\n      numero = numero.slice(1);\n    } else if (Number(DDD) <= 28 && numero.length === 8) {\n      numero = `9${numero}`;\n    }\n\n    return `${DDI}${DDD}${numero}`;\n  }\n\n  // Outros casos: mantém como internacional/indefinido sem adicionar 55\n  return telefoneLimpo;\n}\n\n// Formatação final\nconst formattedNames = capitalizeName(fullNameAnswer);\nconst formattedEmail = formatEmail(emailAnswer);\nconst telefoneFinal = formatTelefone(telefoneClienteOriginal);\nconst dataCadastro = formatDataCadastro(dataRaw, horarioRaw);\nconst urlPagina = formatPageUrl(urlPaginaRaw);\n\n// Resultado\nconst result = {\n  ...formattedNames,\n  email: formattedEmail,\n  whatsapp: telefoneFinal,\n  instagram: \"\",\n  cpf: \"\",\n  cnpj: \"\",\n  utm_source,\n  utm_campaign,\n  utm_term,\n  utm_medium,\n  utm_content,\n  form_id,\n  form_name,\n  page_url: urlPagina,\n  data_cadastro: dataCadastro\n};\n\nreturn [{ json: result }];"
      },
